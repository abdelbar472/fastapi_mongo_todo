{
  "info": {
    "_postman_id": "2a54d445-d099-4e8d-a33b-dc26dcac1df7",
    "name": "fast_mongo TODO API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Root",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      }
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Create Todo",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "if (jsonData.id) {",
              "    pm.collectionVariables.set('todoId', jsonData.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy milk\",\n  \"description\": \"2 liters\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/todos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos"
          ]
        }
      }
    },
    {
      "name": "List Todos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/todos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos"
          ]
        }
      }
    },
    {
      "name": "List Completed Todos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/todos?done=true",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos"
          ],
          "query": [
            {
              "key": "done",
              "value": "true"
            }
          ]
        }
      }
    },
    {
      "name": "Get Todo By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/todos/{{todoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos",
            "{{todoId}}"
          ]
        }
      }
    },
    {
      "name": "Update Todo",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"done\": true,\n  \"title\": \"Buy milk and eggs\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/todos/{{todoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos",
            "{{todoId}}"
          ]
        }
      }
    },
    {
      "name": "Delete Todo",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/todos/{{todoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos",
            "{{todoId}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "todoId",
      "value": ""
    }
  ]
}

